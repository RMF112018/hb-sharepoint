# Microsoft 365 Automation Suite - Environment Variables Template
# Copy this file to .env and fill in your actual values
# DO NOT commit the .env file to version control

# Microsoft Graph API Authentication
# Your Azure AD tenant ID (directory ID)
TENANT_ID=your_tenant_id_here

# Azure AD application (client) ID
CLIENT_ID=your_client_id_here

# Azure AD application client secret
CLIENT_SECRET=your_client_secret_here

# Microsoft Graph API endpoint (usually doesn't need to change)
GRAPH_API_ENDPOINT=https://graph.microsoft.com/v1.0

# Azure AD authentication endpoint
AUTH_ENDPOINT=https://login.microsoftonline.com

# SharePoint site configuration
# Default site URL template (optional)
SITE_URL_TEMPLATE=https://yourtenant.sharepoint.com/sites/{site_name}

# Logging configuration
LOG_LEVEL=INFO
LOG_FILE_PATH=logs/automation.log

# Retry configuration for API calls
MAX_RETRIES=5
RETRY_DELAY=2

# Timeout settings (in seconds)
REQUEST_TIMEOUT=30
CONNECTION_TIMEOUT=10

# Development/Testing flags
DEBUG_MODE=false
DRY_RUN=false
